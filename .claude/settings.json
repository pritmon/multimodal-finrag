{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/pip *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uvicorn *)",
      "Bash(curl *)",
      "Bash(docker *)",
      "Bash(aws *)",
      "Bash(kubectl *)",
      "Bash(eksctl *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(brew *)",
      "Bash(which *)",
      "Bash(source *)",
      "Bash(export *)",
      "Read(**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:shields.io)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then echo '⚠️  Remember: run tests before committing!'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); if echo \"$file\" | grep -q '\\.py$'; then cd \"/Users/pritammondal/CLAUDE CODE/multimodal-finrag\" && .venv/bin/python3 -m py_compile \"$file\" 2>&1 && echo \"✅ Syntax OK: $file\" || echo \"❌ Syntax error in $file\"; fi"
          }
        ]
      }
    ]
  }
}
